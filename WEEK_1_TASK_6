import java.util.Scanner;

public class PowerDigitSum {
    public static void main(String[] args) {

        Scanner sc=new Scanner(System.in);
        String num=sc.next();

        int sum=0;

        for(int i=0;i<num.length();i++){
            int d=num.charAt(i)-'0';
            sum+=Math.pow(d,i+1);
        }

        System.out.println(sum);
    }
}
